# Database
DATABASE_URL=postgresql://user:password@localhost:5432/therapist_billing

# JWT
SECRET_KEY=your-secret-key-min-32-chars-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/onboarding/google-calendar/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_CLIENT_ID=ca_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_REDIRECT_URI=http://localhost:8000/onboarding/stripe/callback
# Primary frontend URL — used in outgoing emails (activation links, invoice links, etc.)
FRONTEND_URL=https://your-app.vercel.app
# Railway backend public URL
BACKEND_URL=https://your-backend.up.railway.app

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourapp.com
EMAIL_FROM_NAME=TherapyBilling

# Encryption key for token storage (Fernet)
ENCRYPTION_KEY=your-fernet-key-here

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=production
# Comma-separated list of ALL frontend domains that may call this API
# Both are allowed for CORS; OAuth redirects automatically go back to whichever domain initiated the flow
CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
